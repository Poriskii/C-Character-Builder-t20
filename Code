   {"Paladin",   {20, 3 }}
};

/*aplicação de classes*/
void applyClass(Character *c){
    int id = c->class_id - 1;

    if(id < 0 || id >= TOTAL_CLASS){
        strcpy(c->class, "Unknown");
        return;
    }

    strcpy(c->class, classes[id].name);

    c->PVPM.Pv = classes[id].PvPmIn[0];
    c->PVPM.Pm = classes[id].PvPmIn[1];
}


