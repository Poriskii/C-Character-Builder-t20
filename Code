#include <stdio.h>
#include <string.h>

#define TOTAL_RACES 17
#define TOTAL_CLASS (sizeof(classes) / sizeof(classes[0]))

typedef struct {
    union {
        struct {
            int strength; 
            int dexterity; 
            int constitution; 
            int intelligence; 
            int wisdom; 
            int charisma;
        };
        int Attr[6];
    };
} Attributes;

typedef struct{
    int Pv;
    int Pm;
} LifeMana;

typedef struct Character {
    char name[30];
    int age;
    
    char race[30];
    int race_id;

    char class[30];
    int class_id;

    LifeMana PVPM;
    Attributes attr;
} Character;

/* =========================
   RACE SYSTEM
========================= */

typedef struct {
    char name[20];
    int mod[6];
    void (*special)(Character*);
} Race;

/* funções especiais */
void suraggelSpecial(Character *c){
    char choice[20];

    printf("Choose type (aggelus/sulfure): ");
    scanf("%19s", choice);

    if (strcmp(choice, "aggelus") == 0) {
        c->attr.wisdom += 2;
        c->attr.charisma += 1;
    } 
    else if (strcmp(choice, "sulfure") == 0) {
        c->attr.dexterity += 2;
        c->attr.intelligence += 1;
    }
}

/* tabela de raças */
Race races[TOTAL_RACES] = {
    {"Dwarf",    { 0, -1, +2,  0, +1,  0}, NULL},
    {"Dahllan",  { 0, +1,  0, -1, +2,  0}, NULL},
    {"Elf",      { 0, +1, -1, +2,  0,  0}, NULL},
    {"Goblin",   { 0, +2,  0, +1,  0, -1}, NULL},
    {"Golem",    {+2,  0, +1,  0,  0, -1}, NULL},
    {"Human",    { 0,  0,  0,  0,  0,  0}, NULL},
    {"Hynne",    {-1, +2,  0,  0,  0, +1}, NULL},
    {"Kliren",   {-1,  0,  0, +2,  0, +1}, NULL},
    {"Lefou",    { 0,  0,  0,  0,  0,  0}, NULL},
    {"Medusa",   { 0, +2,  0,  0,  0, +1}, NULL},
    {"Minotaur", {+2,  0, +1,  0, -1,  0}, NULL},
    {"Osteon",   { 0,  0,  0,  0,  0,  0}, NULL},
    {"Qareen",   { 0,  0,  0, +1, -1, +2}, NULL},
    {"Mermaid",  { 0,  0,  0,  0,  0,  0}, NULL},
    {"Sylph",    {-2, +1,  0,  0,  0, +2}, NULL},
    {"Suraggel", { 0,  0,  0,  0,  0,  0}, suraggelSpecial},
    {"Trog",     {+1,  0, +2, -1,  0,  0}, NULL}
};

/* aplica raça */
void applyRace(Character *c){
    int id = c->race_id - 1;

    if(id < 0 || id >= TOTAL_RACES){
        strcpy(c->race, "Unknown");
        return;
    }

    strcpy(c->race, races[id].name);

    for(int i = 0; i < 6; i++){
        c->attr.Attr[i] += races[id].mod[i];
    }

    if(races[id].special != NULL){
        races[id].special(c);
    }
}

