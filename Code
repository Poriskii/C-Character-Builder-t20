/* =========================
   DEBUG / OUTPUT
========================= */

void printCharacter(Character *c){
    printf("\n=== CHARACTER ===\n");
    printf("Name: %s\n", c->name);
    printf("Age: %d\n", c->age);
    printf("Race: %s\n", c->race);
    printf("Class: %s\n", c->class);

    printf("PV: %d\n", c->PVPM.Pv);
    printf("PM: %d\n", c->PVPM.Pm);

    printf("\nAttributes:\n");
    printf("STR: %d\n", c->attr.strength);
    printf("DEX: %d\n", c->attr.dexterity);
    printf("CON: %d\n", c->attr.constitution);
    printf("INT: %d\n", c->attr.intelligence);
    printf("WIS: %d\n", c->attr.wisdom);
    printf("CHA: %d\n", c->attr.charisma);
}

